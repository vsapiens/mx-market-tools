{
  "name": "@mx-market/data",
  "version": "0.1.1",
  "description": "Datos de mercado de Yahoo Finance para acciones mexicanas (BMV/SIC)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc"
  },
  "peerDependencies": {
    "yahoo-finance2": "^2.0.0 || ^3.0.0"
  },
  "peerDependenciesMeta": {
    "yahoo-finance2": {
      "optional": true
    }
  },
  "keywords": [
    "bmv",
    "bolsa",
    "mexico",
    "yahoo-finance",
    "market-data",
    "ohlcv"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vsapiens/mx-market-tools",
    "directory": "packages/data"
  }
}
